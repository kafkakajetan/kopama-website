generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum EnrollmentStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELED
}

enum PaymentStatus {
  REGISTERED
  SUCCESS
  REJECTED
  CANCELED
  ERROR
}

enum OfferLanguage {
  PL
  EN
}

enum ContractStatus {
  NOT_GENERATED
  GENERATED
  DOWNLOADED
  MANUAL_DELIVERY_PENDING
}

model User {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  email           String           @unique
  phone           String?
  passwordHash    String?
  role            UserRole         @default(STUDENT)

  firstName       String?
  lastName        String?

  enrollments     Enrollment[]

  specializations CourseCategory[] @relation("InstructorSpecializations")
  drivingCategories  DrivingCategory[] @relation("InstructorDrivingCategories")
}

model DrivingCategory {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  minAge      Int?
  description String?
  sortOrder   Int    @default(0)

  instructors User[] @relation("InstructorDrivingCategories")
}

model CourseCategory {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  enrollments Enrollment[]
  offerItems  OfferItem[]
  instructors  User[] @relation("InstructorSpecializations")
}

model Enrollment {
  id     String           @id @default(cuid())
  status EnrollmentStatus @default(DRAFT)

  firstName String
  lastName  String
  email     String
  phone     String
  pesel     String

  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String

  birthDate       DateTime
  courseMode      CourseMode
  courseStartDate DateTime?

  hasOtherDrivingLicense      Boolean @default(false)
  otherDrivingLicenseCategory String?
  otherDrivingLicenseNumber   String?

  hasTramPermit     Boolean @default(false)
  tramPermitNumber  String?

  wantsCashPayment  Boolean @default(false)

  isMinorAtPurchase Boolean @default(false)

  guardianPesel        String?
  guardianFirstName    String?
  guardianLastName     String?
  guardianPhone        String?
  guardianAddressLine1 String?
  guardianAddressLine2 String?
  guardianCity         String?
  guardianPostalCode   String?

  guardianSameAddress  Boolean? @default(false)

  acceptedTermsAt            DateTime
  acceptedSalesTermsAt       DateTime?
  acceptedSalesTermsVersion  String?
  acceptedPrivacyAt          DateTime
  acceptedIp                 String?

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  courseCategoryId String
  courseCategory   CourseCategory @relation(fields: [courseCategoryId], references: [id])

  offerItemId String
  offerItem   OfferItem @relation(fields: [offerItemId], references: [id])

  payment  PaymentTransaction?
  contract ContractDocument?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([userId])
}

model PaymentTransaction {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  status       PaymentStatus @default(REGISTERED)
  amountGrosze Int
  currency     String        @default("PLN")

  p24SessionId String? @unique
  p24OrderId   String? @unique

  lastWebhookAt DateTime?
  rawPayload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ContractDocument {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  status      ContractStatus @default(NOT_GENERATED)
  templateVer String         @default("v1")

  storageKey  String
  fileHash    String?
  generatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OfferType {
  COURSE
  EXTRA_HOUR
  EXAM_CAR
  TRAINING_PACKAGE
  OTHER
}

enum OfferUnit {
  PACKAGE
  HOUR
  SERVICE
}

enum CustomerType {
  PUBLIC
  KOPAMA_STUDENT
}

enum CourseMode {
  STATIONARY
  ELEARNING
}

model OfferItem {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  type     OfferType
  unit     OfferUnit
  isActive Boolean   @default(true)

  courseCategoryId String?
  courseCategory   CourseCategory? @relation(fields: [courseCategoryId], references: [id])

  language OfferLanguage @default(PL)

  enrollments Enrollment[]

  priceRules PriceRule[]
  courseStartSlots CourseStartSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceRule {
  id          String    @id @default(cuid())
  offerItemId String
  offerItem   OfferItem @relation(fields: [offerItemId], references: [id])

  customerType CustomerType
  priceZloty   Decimal      @db.Decimal(10, 2)
  currency     String       @default("PLN")

  validFrom DateTime?
  validTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offerItemId, customerType, validFrom, validTo])
  @@index([offerItemId])
}

model CourseStartSlot {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startDate   DateTime
  isActive    Boolean   @default(true)
  notes       String?

  offerItemId String
  offerItem   OfferItem @relation(fields: [offerItemId], references: [id], onDelete: Cascade)

  @@unique([offerItemId, startDate])
  @@index([offerItemId, startDate, isActive])
}